#
# The standard name for this image is ovn-kube-ubuntu

# Notes:
# This is for a development build where the ovn-kubernetes utilities
# are built in this Dockerfile and included in the image (instead of the deb package)
#
#
# So this file will change over time.

ARG BUILDER_IMAGE
ARG OVN_KUBERNETES_DIR=.

FROM --platform=${BUILDPLATFORM} ${BUILDER_IMAGE} AS ovnkube-builder

ARG OVN_KUBERNETES_DIR
ARG TARGETOS
ARG TARGETARCH

WORKDIR /workspace
RUN dnf install --best --refresh -y make git
COPY ${OVN_KUBERNETES_DIR} ovn-kubernetes
RUN cd ovn-kubernetes/dist/images && \
    CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} make bld

FROM ubuntu:26.04

ARG TARGETARCH

USER root

# Install runtime dependencies and OVS/OVN packages in one layer so a single
# package index update covers the full install set.
RUN apt-get update && apt-get install -y \
    iproute2 curl software-properties-common util-linux nftables \
    openvswitch-switch openvswitch-common ovn-central ovn-common ovn-host && \
    rm -rf /var/lib/apt/lists/*

RUN curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/${TARGETARCH}/kubectl" \
    && install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl

# Built in the ovnkube-builder stage, then the binaries are copied here.
# put things where they are in the pkg
RUN mkdir -p /var/run/openvswitch /usr/libexec/cni/
COPY --from=ovnkube-builder /workspace/ovn-kubernetes/dist/images/ovnkube /workspace/ovn-kubernetes/dist/images/ovn-kube-util /workspace/ovn-kubernetes/dist/images/hybrid-overlay-node /workspace/ovn-kubernetes/dist/images/ovnkube-identity /workspace/ovn-kubernetes/dist/images/ovnkube-observ /usr/bin/
COPY --from=ovnkube-builder /workspace/ovn-kubernetes/dist/images/ovn-k8s-cni-overlay /usr/libexec/cni/ovn-k8s-cni-overlay

# ovnkube.sh is the entry point. This script examines environment
# variables to direct operation and configure ovn
COPY --from=ovnkube-builder /workspace/ovn-kubernetes/dist/images/ovnkube.sh /workspace/ovn-kubernetes/dist/images/git_info /root/
# override the pkg's ovn_k8s.conf with this local copy
COPY --from=ovnkube-builder /workspace/ovn-kubernetes/dist/images/ovn_k8s.conf /etc/openvswitch/ovn_k8s.conf

# include checked-in third-party license files in the final image
COPY LICENSES/ /usr/share/licenses/ovn-kubernetes/

# iptables wrappers
COPY --from=ovnkube-builder /workspace/ovn-kubernetes/dist/images/iptables-scripts/iptables /workspace/ovn-kubernetes/dist/images/iptables-scripts/iptables-save /workspace/ovn-kubernetes/dist/images/iptables-scripts/iptables-restore /workspace/ovn-kubernetes/dist/images/iptables-scripts/ip6tables /workspace/ovn-kubernetes/dist/images/iptables-scripts/ip6tables-save /workspace/ovn-kubernetes/dist/images/iptables-scripts/ip6tables-restore /usr/sbin/

LABEL io.k8s.display-name="ovn-kubernetes" \
      io.k8s.description="ovnkube ubuntu image" 

WORKDIR /root
ENTRYPOINT /root/ovnkube.sh
